{
    "blocks": {
        "faq": {
            "key": "faq",
            "view": "cms.blocks.faq",
            "plugin": null,
            "label": "FAQ",
            "icon": "heroicon-o-question-mark-circle",
            "fields": [
                {
                    "name": "heading",
                    "type": "text",
                    "label": "T\u00edtulo da sec\u00e7\u00e3o",
                    "default": "FAQ"
                },
                {
                    "name": "items",
                    "type": "repeater",
                    "fields": [
                        {
                            "name": "question",
                            "type": "text",
                            "label": "Pergunta",
                            "required": true
                        },
                        {
                            "name": "answer",
                            "type": "textarea",
                            "label": "Resposta",
                            "required": true
                        }
                    ],
                    "label": "Perguntas"
                }
            ]
        },
        "hero": {
            "key": "hero",
            "view": "cms.blocks.hero",
            "plugin": null,
            "label": "Hero",
            "icon": "heroicon-o-photo",
            "fields": [
                {
                    "name": "title",
                    "type": "text",
                    "label": "T\u00edtulo",
                    "required": true
                },
                {
                    "name": "subtitle",
                    "type": "text",
                    "label": "Subt\u00edtulo"
                },
                {
                    "name": "cta",
                    "type": "link",
                    "label": "Call to action"
                }
            ]
        },
        "image": {
            "key": "image",
            "view": "cms.blocks.image",
            "plugin": null,
            "label": "Imagem",
            "icon": "heroicon-o-camera",
            "fields": [
                {
                    "name": "image",
                    "type": "media",
                    "label": "Imagem",
                    "required": true
                },
                {
                    "name": "caption",
                    "type": "text",
                    "label": "Legenda"
                }
            ]
        },
        "richtext": {
            "key": "richtext",
            "view": "cms.blocks.richtext",
            "plugin": null,
            "label": "Texto",
            "icon": "heroicon-o-document-text",
            "fields": [
                {
                    "name": "content",
                    "type": "richtext",
                    "label": "Conte\u00fado",
                    "required": true
                }
            ]
        },
        "testimonials.quote": {
            "key": "testimonials.quote",
            "view": "testimonials::blocks.quote",
            "plugin": "testimonials",
            "label": "Cita\u00e7\u00e3o",
            "icon": "heroicon-o-chat-bubble-left-right",
            "fields": [
                {
                    "name": "quote",
                    "type": "textarea",
                    "label": "Cita\u00e7\u00e3o",
                    "required": true
                },
                {
                    "name": "author",
                    "type": "text",
                    "label": "Autor",
                    "required": true
                }
            ]
        },
        "testimonials.wall": {
            "key": "testimonials.wall",
            "view": "testimonials::blocks.wall",
            "plugin": "testimonials",
            "label": "Mural de testemunhos",
            "icon": "heroicon-o-squares-2x2",
            "fields": [
                {
                    "name": "testimonials",
                    "type": "repeater",
                    "fields": [
                        {
                            "name": "quote",
                            "type": "textarea",
                            "label": "Cita\u00e7\u00e3o",
                            "required": true
                        },
                        {
                            "name": "author",
                            "type": "text",
                            "label": "Autor",
                            "required": true
                        },
                        {
                            "name": "company",
                            "type": "text",
                            "label": "Empresa"
                        }
                    ],
                    "label": "Testemunhos"
                }
            ]
        }
